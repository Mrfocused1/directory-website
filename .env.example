# Database (Supabase Postgres)
DATABASE_URL=postgresql://postgres.xxx:[YOUR-PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Stripe (payments & subscriptions)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (transactional email)
RESEND_API_KEY=re_...

# Apify (content scraping)
APIFY_API_TOKEN=apify_api_...

# Deepgram (video transcription)
DEEPGRAM_API_KEY=...

# Claude API (auto-categorization)
ANTHROPIC_API_KEY=sk-ant-...

# Inngest (background jobs)
INNGEST_EVENT_KEY=...
INNGEST_SIGNING_KEY=signkey-...

# Vercel Blob (media storage — auto-configured on Vercel)
BLOB_READ_WRITE_TOKEN=vercel_blob_...

# Vercel (domain management — optional)
VERCEL_PROJECT_ID=prj_...
VERCEL_TEAM_ID=team_...
VERCEL_API_TOKEN=...

# SearXNG (meta-search engine — self-hosted)
SEARXNG_URL=http://localhost:8080

# Piper TTS (text-to-speech — self-hosted)
PIPER_TTS_URL=http://localhost:5000

# LibreTranslate (translation — self-hosted)
LIBRETRANSLATE_URL=http://localhost:5555

# ── Upstash Redis (rate limiting) ──────────────────────────────────
# Free tier: 10,000 commands/day. Sign up at https://upstash.com
# Falls back to in-memory (ephemeral) when not set.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Session Recovery ───────────────────────────────────────────────
# Self-heals the VPS's Instagram session when it's flagged. The
# recovery itself runs on the VPS (reuses the existing Puppeteer +
# IPRoyal proxy setup); Vercel just orchestrates and emails on
# failure. Set a shared secret to gate POST /api/session/recover and
# an email to notify when 2FA/CAPTCHA requires a human.
SESSION_RECOVERY_KEY=
SESSION_RECOVERY_ALERT_EMAIL=

# ── Manual build workflow (operator notifications) ─────────────────
# When a creator clicks "Build my directory", the app doesn't fire
# the pipeline automatically — it pings the operator (you) via email
# and telegram so you can run `bash scripts/build-site.sh <slug>`
# from your Mac at your terminal.
#
# BUILD_OPERATOR_EMAIL    — falls back to SESSION_RECOVERY_ALERT_EMAIL
# TELEGRAM_BOT_TOKEN      — from @BotFather: /newbot → follow prompts → copy the token
# TELEGRAM_CHAT_ID        — send any message to your new bot, then visit
#                           https://api.telegram.org/bot<TOKEN>/getUpdates
#                           and copy the "chat":{"id":...} value. For a
#                           personal chat this is a positive int; for a
#                           group chat it's negative.
BUILD_OPERATOR_EMAIL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
