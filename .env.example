# Database (Supabase Postgres)
DATABASE_URL=postgresql://postgres.xxx:[YOUR-PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres

# Supabase Auth
# Legacy JWT keys (still work):
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# New API keys (preferred, scoped by role):
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# Admin allowlist (comma-separated emails with platform-owner powers)
ADMIN_EMAILS=you@example.com,alt@example.com

# Stripe (payments & subscriptions)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (transactional email)
RESEND_API_KEY=re_...

# Apify (content scraping)
APIFY_API_TOKEN=apify_api_...

# Deepgram (video transcription)
DEEPGRAM_API_KEY=...

# Claude API (auto-categorization)
ANTHROPIC_API_KEY=sk-ant-...

# Groq (fallback transcription + fast inference)
GROQ_API_KEY=gsk_...

# Inngest (background jobs)
INNGEST_EVENT_KEY=...
INNGEST_SIGNING_KEY=signkey-...

# Vercel Blob (media storage — auto-configured on Vercel)
BLOB_READ_WRITE_TOKEN=vercel_blob_...

# Storage backend selector: "blob" (Vercel Blob) or "r2" (Cloudflare R2)
STORAGE_PROVIDER=blob

# Cloudflare R2 (only required when STORAGE_PROVIDER=r2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
R2_BUCKET=
R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# Vercel (domain management — optional)
VERCEL_PROJECT_ID=prj_...
VERCEL_TEAM_ID=team_...
VERCEL_API_TOKEN=...

# SearXNG (meta-search engine — self-hosted)
SEARXNG_URL=http://localhost:8080

# Piper TTS (text-to-speech — self-hosted)
PIPER_TTS_URL=http://localhost:5000

# LibreTranslate (translation — self-hosted)
LIBRETRANSLATE_URL=http://localhost:5555

# ── Scraper backend ────────────────────────────────────────────────
# SCRAPER_PROVIDER chooses where Instagram posts come from:
#   "vps"    — self-hosted VPS (scripts/vps-scraper/server.mjs) — default
#   "apify"  — Apify managed scraper (fallback, costs money)
#   "vast"   — Vast.ai on-demand GPU (experimental)
SCRAPER_PROVIDER=vps
SCRAPER_VPS_URL=http://your-vps:3001
SCRAPER_VPS_API_KEY=
VAST_API_KEY=

# ── Observability ──────────────────────────────────────────────────
# Sentry (error tracking). NEXT_PUBLIC_SENTRY_DSN is for client-side;
# SENTRY_DSN for server. SENTRY_AUTH_TOKEN uploads source maps on build.
NEXT_PUBLIC_SENTRY_DSN=https://...@...ingest.de.sentry.io/...
SENTRY_DSN=https://...@...ingest.de.sentry.io/...
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project
SENTRY_AUTH_TOKEN=sntrys_...

# PostHog (product analytics). Both server-side (POSTHOG_*) and client
# (NEXT_PUBLIC_POSTHOG_*) get the same values but must be set twice so
# Next.js bundles the public ones into client code.
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_KEY=phc_...
POSTHOG_HOST=https://us.i.posthog.com

# Checkly (synthetic monitoring — runs the tests in src/__checks__)
CHECKLY_API_KEY=
CHECKLY_ACCOUNT_ID=

# ── Upstash Redis (rate limiting) ──────────────────────────────────
# Free tier: 10,000 commands/day. Sign up at https://upstash.com
# Falls back to in-memory (ephemeral) when not set.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Session Recovery ───────────────────────────────────────────────
# Self-heals the VPS's Instagram session when it's flagged. The
# recovery itself runs on the VPS (reuses the existing Puppeteer +
# IPRoyal proxy setup); Vercel just orchestrates and emails on
# failure. Set a shared secret to gate POST /api/session/recover and
# an email to notify when 2FA/CAPTCHA requires a human.
SESSION_RECOVERY_KEY=
SESSION_RECOVERY_ALERT_EMAIL=

# ── Manual build workflow (operator notifications) ─────────────────
# When a creator clicks "Build my directory", the app doesn't fire
# the pipeline automatically — it pings the operator (you) via email
# and telegram so you can run `bash scripts/build-site.sh <slug>`
# from your Mac at your terminal.
#
# BUILD_OPERATOR_EMAIL    — falls back to SESSION_RECOVERY_ALERT_EMAIL
# TELEGRAM_BOT_TOKEN      — from @BotFather: /newbot → follow prompts → copy the token
# TELEGRAM_CHAT_ID        — send any message to your new bot, then visit
#                           https://api.telegram.org/bot<TOKEN>/getUpdates
#                           and copy the "chat":{"id":...} value. For a
#                           personal chat this is a positive int; for a
#                           group chat it's negative.
BUILD_OPERATOR_EMAIL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Phase 4 advertising (no new env vars required) ─────────────────
# Ad purchases use the existing Stripe Connect setup (STRIPE_SECRET_KEY
# + STRIPE_WEBHOOK_SECRET). The only action required in Stripe dashboard:
#
#   1. Go to Developers > Webhooks > your endpoint
#   2. Add "checkout.session.completed" to the list of subscribed events
#      (it may already be subscribed — if so, no change needed).
#
# Ad creative uploads use the existing STORAGE_PROVIDER / R2 / Blob
# config — no new bucket or path setup required.
#
# Ad notification emails use the existing RESEND_API_KEY.
#
# No new environment variables needed for Phase 4.
